# ==============================================================================
# Memorang Backend (NestJS) — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_PDF_CONTAINER=pdfs
AZURE_STORAGE_IMAGE_CONTAINER=extracted-images

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=
# Optional. Reasoning-style deployments only accept the default temperature (1).
# Set to true (or AZURE_OPENAI_CHAT_TEMPERATURE=0.2) for models that support custom temperature.
# AZURE_OPENAI_CHAT_SUPPORTS_TEMPERATURE=true
# AZURE_OPENAI_CHAT_TEMPERATURE=

# ── Azure Document Intelligence ───────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-ingestion

# ── Document Ingestion Performance ────────────────────────────────────────────
# Parallel figure download/upload concurrency during PDF ingestion (default: 12)
# FIGURE_EXTRACTION_CONCURRENCY=12
# Parallel vision classification batch size (default: 16)
# VISION_CLASSIFICATION_CONCURRENCY=16

# ── LangGraph Persistence ─────────────────────────────────────────────────────
# Must be a real Postgres connection string. Supabase Postgres works well here.
LANGGRAPH_POSTGRES_URL=
# Optional. Defaults to public. Only set a custom schema after creating it.
LANGGRAPH_POSTGRES_SCHEMA=public

# ── LangSmith Tracing ──────────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=MEMORANG
LANGSMITH_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
