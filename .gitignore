# ============================
# Dependencies
# ============================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ============================
# Next.js build artifacts
# ============================
.next/
out/
build/
dist/

# ============================
# Environment files (NEVER commit these)
# ============================
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
!.env.example
!**/.env.example

# ============================
# Debug logs
# ============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================
# TypeScript
# ============================
*.tsbuildinfo
next-env.d.ts

# ============================
# OS files
# ============================
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ============================
# Docker
# ============================
# Keep .dockerignore files tracked for image builds
!.dockerignore
!**/.dockerignore

# ============================
# Secrets and certificates
# ============================
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
k8s/secrets/*.local.yaml
k8s/secrets/*.generated.yaml
k8s/secrets/doppler-tokens.yaml
k8s/temporal/postgres-secret.yaml
k8s/tickertom-ingress.yaml
# Local builds may embed VITE_* values from .env.local
frontend/dist/

# ============================
# Misc
# ============================
coverage/
*.log
.vercel
**/__pycache__/
*.py[cod]
